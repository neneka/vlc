+++ b/src/renderer/text_renderer_coretext.cpp
@@ -17,6 +17,7 @@
  */
 
 #include <CoreFoundation/CoreFoundation.h>
+#include <algorithm>
 #include <cmath>
 #include <utility>
 #include "base/cfstr_helper.hpp"
@@ -28,6 +29,61 @@
 
 namespace aribcaption {
 
+namespace {
+
+bool GetFirstShapedGlyph(CTFontRef ctfont, const std::u16string& utf16, size_t codeunit_count,
+                         CGGlyph* out_glyph, CGSize* out_advance) {
+    ScopedCFRef<CFStringRef> string(CFStringCreateWithCharacters(kCFAllocatorDefault,
+                                                                 reinterpret_cast<const UniChar*>(utf16.data()),
+                                                                 static_cast<CFIndex>(codeunit_count)));
+    if (!string) {
+        return false;
+    }
+
+    ScopedCFRef<CFMutableAttributedStringRef> attr_string(
+        CFAttributedStringCreateMutable(kCFAllocatorDefault, 0));
+    if (!attr_string) {
+        return false;
+    }
+
+    CFAttributedStringReplaceString(attr_string.get(), CFRangeMake(0, 0), string.get());
+    CFAttributedStringSetAttribute(attr_string.get(),
+                                   CFRangeMake(0, CFStringGetLength(string.get())),
+                                   kCTFontAttributeName,
+                                   ctfont);
+
+    ScopedCFRef<CTLineRef> line(CTLineCreateWithAttributedString(attr_string.get()));
+    if (!line) {
+        return false;
+    }
+
+    CFArrayRef runs = CTLineGetGlyphRuns(line.get());
+    if (!runs || CFArrayGetCount(runs) != 1) {
+        return false;
+    }
+
+    CTRunRef run = static_cast<CTRunRef>(const_cast<void*>(CFArrayGetValueAtIndex(runs, 0)));
+    if (!run || CTRunGetGlyphCount(run) != 1) {
+        return false;
+    }
+
+    CTRunGetGlyphs(run, CFRangeMake(0, 1), out_glyph);
+    CTRunGetAdvances(run, CFRangeMake(0, 1), out_advance);
+    return *out_glyph != 0 && out_advance->width > 0.0;
+}
+
+bool HalfWidthGlyphFits(CTFontRef ctfont, CGGlyph glyph, CGFloat advance, int char_width, int char_height) {
+    const CGFloat tolerance = std::max<CGFloat>(1.0f, static_cast<CGFloat>(char_height) * 0.05f);
+    CGRect bounds = CGRectZero;
+    CTFontGetBoundingRectsForGlyphs(ctfont, kCTFontOrientationHorizontal, &glyph, &bounds, 1);
+    const CGFloat right = bounds.origin.x + bounds.size.width;
+    return advance <= static_cast<CGFloat>(char_width) + tolerance &&
+           bounds.origin.x >= -tolerance &&
+           right <= static_cast<CGFloat>(char_width) + tolerance;
+}
+
+}  // namespace
+
 TextRendererCoreText::TextRendererCoreText(Context& context, FontProvider& font_provider)
     : log_(GetContextLogger(context)), font_provider_(font_provider) {}
 
@@ -62,6 +118,10 @@ bool TextRendererCoreText::SetFontFamily(const std::vector<std::string>& font_fa
     return true;
 }
 
+void TextRendererCoreText::SetReplaceMSZHalfWidthGlyph(bool replace) {
+    replace_msz_halfwidth_glyph_ = replace;
+}
+
 struct TextRenderContextPrivateCoreText : public TextRenderContext::ContextPrivate {
 public:
     TextRenderContextPrivateCoreText() = default;
@@ -198,6 +258,34 @@ auto TextRendererCoreText::DrawChar(TextRenderContext& render_ctx, int target_x,
                                  glyphs,
                                  static_cast<CFIndex>(codeunit_count));
 
+    // Check if it is MSZ (Middle Size)
+    bool is_requesting_halfwidth = floating::AlmostEquals(aspect_ratio, 0.5f, 0.05f);
+    CGSize glyph_advance = CGSizeZero;
+    CTFontGetAdvancesForGlyphs(ctfont, kCTFontOrientationHorizontal, &glyphs[0], &glyph_advance, 1);
+    bool use_halfwidth_glyph = false;
+    ScopedCFRef<CTFontRef> halfwidth_ctfont_sized;
+    if (replace_msz_halfwidth_glyph_ && is_requesting_halfwidth) {
+        halfwidth_ctfont_sized = CreateHalfWidthCTFont(ctfont);
+        if (halfwidth_ctfont_sized) {
+            CGGlyph halfwidth_glyph = 0;
+            CGSize halfwidth_advance = CGSizeZero;
+            if (GetFirstShapedGlyph(halfwidth_ctfont_sized.get(),
+                                    utf16,
+                                    codeunit_count,
+                                    &halfwidth_glyph,
+                                    &halfwidth_advance) &&
+                HalfWidthGlyphFits(halfwidth_ctfont_sized.get(),
+                                   halfwidth_glyph,
+                                   halfwidth_advance.width,
+                                   char_width,
+                                   char_height)) {
+                glyphs[0] = halfwidth_glyph;
+                ctfont = halfwidth_ctfont_sized.get();
+                use_halfwidth_glyph = true;
+            }
+        }
+    }
+
     CGFloat ascent = CTFontGetAscent(ctfont);
     CGFloat descent = CTFontGetDescent(ctfont);
     CGFloat em_height = ascent + descent;
@@ -228,9 +316,11 @@ auto TextRendererCoreText::DrawChar(TextRenderContext& render_ctx, int target_x,
 
     CGPoint origin = CGPointMake(target_x, baseline_y);
 
-    // Check if it is MSZ (Middle Size)
-    bool is_requesting_halfwidth = floating::AlmostEquals(aspect_ratio, 0.5f, 0.05f);
-    bool needless_horizontal_scaling = is_requesting_halfwidth && unicode::IsHalfwidthCharacter(ucs4);
+    bool glyph_already_fits_halfwidth =
+        HalfWidthGlyphFits(ctfont, glyphs[0], glyph_advance.width, char_width, char_height);
+    bool needless_horizontal_scaling =
+        is_requesting_halfwidth && unicode::IsHalfwidthCharacter(ucs4) &&
+        (use_halfwidth_glyph || glyph_already_fits_halfwidth);
 
     // Scale character correctly if char_width is different from char_height
     // Do not do horizontal scaling if the character is halfwidth already
@@ -334,4 +424,59 @@ auto TextRendererCoreText::CreateSizedCTFont(CTFontRef ctfont, int char_height)
     return sized_ctfont;
 }
 
+auto TextRendererCoreText::CreateHalfWidthCTFont(CTFontRef ctfont) -> ScopedCFRef<CTFontRef> {
+    int feature_value = 1;
+    ScopedCFRef<CFNumberRef> cf_feature_value(CFNumberCreate(nullptr, kCFNumberIntType, &feature_value));
+    if (!cf_feature_value) {
+        return nullptr;
+    }
+
+    const void* feature_keys[] = {
+        kCTFontOpenTypeFeatureTag,
+        kCTFontOpenTypeFeatureValue,
+    };
+    const void* feature_values[] = {
+        CFSTR("hwid"),
+        cf_feature_value.get(),
+    };
+    ScopedCFRef<CFDictionaryRef> feature(CFDictionaryCreate(kCFAllocatorDefault,
+                                                            feature_keys,
+                                                            feature_values,
+                                                            2,
+                                                            &kCFTypeDictionaryKeyCallBacks,
+                                                            &kCFTypeDictionaryValueCallBacks));
+    if (!feature) {
+        return nullptr;
+    }
+
+    const void* features[] = { feature.get() };
+    ScopedCFRef<CFArrayRef> feature_settings(CFArrayCreate(kCFAllocatorDefault,
+                                                           features,
+                                                           1,
+                                                           &kCFTypeArrayCallBacks));
+    if (!feature_settings) {
+        return nullptr;
+    }
+
+    const void* descriptor_keys[] = { kCTFontFeatureSettingsAttribute };
+    const void* descriptor_values[] = { feature_settings.get() };
+    ScopedCFRef<CFDictionaryRef> descriptor_attributes(CFDictionaryCreate(kCFAllocatorDefault,
+                                                                         descriptor_keys,
+                                                                         descriptor_values,
+                                                                         1,
+                                                                         &kCFTypeDictionaryKeyCallBacks,
+                                                                         &kCFTypeDictionaryValueCallBacks));
+    if (!descriptor_attributes) {
+        return nullptr;
+    }
+
+    ScopedCFRef<CTFontDescriptorRef> descriptor(CTFontDescriptorCreateWithAttributes(descriptor_attributes.get()));
+    if (!descriptor) {
+        return nullptr;
+    }
+
+    ScopedCFRef<CTFontRef> halfwidth_ctfont(CTFontCreateCopyWithAttributes(ctfont, 0.0f, nullptr, descriptor.get()));
+    return halfwidth_ctfont;
+}
+
 }  // namespace aribcaption
